import java.io.FilterOutputStream;
import java.lang.reflect.Array;
import java.util.ArrayList;
import java.util.Arrays;

public class portfolio1 {
//    Method to count local peaks
    public static int Main1(ArrayList <Integer> temps) {
        int count = 0;
        // Start from index 1 and stop before last index
        for (int i = 1; i < temps.size() - 1; i++){
//            Checks if current tempreture is greater and then previous and text temp
            if(temps.get(i) > temps.get(i - 1)
                    && temps.get(i) > temps.get(i + 1)){
                count++;
            }
        }

        return count;
    }


    public static void main(String[] args) {
    //Test cases
//      Test case 1
        ArrayList<Integer> temps1 = new ArrayList<>(Arrays.asList(20, 25, 22, 30, 28));
        System.out.println(Main1(temps1));
//      Test case 2
        ArrayList<Integer> temps2 = new ArrayList<>( Arrays.asList(10, 15,20, 15, 20, 10));
        System.out.println(Main1(temps2));
//      Test case 3
        ArrayList<Integer> temps3 = new ArrayList<>( Arrays.asList(5, 10, 15, 20, 25));
        System.out.println(Main1(temps3));

    }
}



