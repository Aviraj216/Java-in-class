// Base class
class Book {

    // Variables
    String title;
    int copiesAvailable;

    // Constructor
    Book(String title, int copiesAvailable) {
        this.title = title;
        this.copiesAvailable = copiesAvailable;
    }

    // Method to borrow a book
    void borrowBook(int copies) {

        // Check if enough copies are available
        if (copies <= copiesAvailable) {
            copiesAvailable = copiesAvailable - copies;

            // Show remaining copies
            System.out.println("Book borrowed successfully.");
            System.out.println("Remaining copies: " + copiesAvailable);
        } else {
            // Not enough copies
            System.out.println("Not enough copies available.");
        }
    }
}

// Child class
class RegularBook extends Book {

    // Constructor
    RegularBook(String title, int copiesAvailable) {
        super(title, copiesAvailable);
    }
}

// Child class
class ReferenceBook extends Book {
    // Constructor
    ReferenceBook(String title, int copiesAvailable) {
        super(title, copiesAvailable);
    }

    // Override borrowBook method
    @Override
    void borrowBook(int copies) {

        // Reference books cannot be borrowed
        System.out.println("Reference books cannot be borrowed.");
    }
}

// Main class
public class Main {

    public static void main(String[] args) {

        // Create a regular book
        RegularBook book1 = new RegularBook("Java Programming", 10);

        // Create a reference book
        ReferenceBook book2 = new ReferenceBook("Dictionary", 5);

        // Successful borrow
        System.out.println("Regular Book:");
        book1.borrowBook(3);

        System.out.println();

        // Unsuccessful borrow (Reference book)
        System.out.println("Reference Book:");
        book2.borrowBook(1);
    }
}




